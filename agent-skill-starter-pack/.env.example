# ──────────────────────────────────────────────
# Agent Skill Starter Pack — Environment Config
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# ── Application ──────────────────────────────
NODE_ENV=development
AGENT_ID=my-agent-001
LOG_LEVEL=info
PRETTY_LOGS=true

# ── Server ────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Cache (optional — falls back to in-memory) 
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true

# ── LLM Providers ─────────────────────────────
# Required for: data-analysis (insights), nlp (entities, summary, classify),
#               api-integration (N/A), web-scraper (N/A)
OPENAI_API_KEY=sk-...your-openai-key...
ANTHROPIC_API_KEY=sk-ant-...your-anthropic-key...
DEFAULT_MODEL=gpt-4o-mini

# ── Security ──────────────────────────────────
API_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# ── Monitoring ────────────────────────────────
METRICS_ENABLED=true
# Optional: Slack/PagerDuty/Teams webhook for alerts
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...
