{
  "name": "agent-skill-starter-pack",
  "version": "1.0.0",
  "description": "Production-ready AI agent skill framework with modular, plug-and-play architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "typecheck": "tsc --noEmit",
    "docs:generate": "typedoc src/index.ts",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "skill:create": "ts-node scripts/create-skill.ts",
    "skill:validate": "ts-node scripts/validate-skill.ts",
    "health:check": "ts-node scripts/health-check.ts"
  },
  "keywords": [
    "ai-agent",
    "skill-framework",
    "mcp",
    "langgraph",
    "autonomous-agents"
  ],
  "author": "AI Engineering Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bullmq": "^5.1.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "openai": "^4.28.0",
    "p-retry": "^6.2.0",
    "p-timeout": "^6.1.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "playwright": "^1.41.0",
    "zod": "^3.22.4",
    "uuid": "^9.0.0",
    "lodash": "^4.17.21",
    "dayjs": "^1.11.10",
    "natural": "^6.10.4",
    "compromise": "^14.10.0"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^29.5.11",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "msw": "^2.1.2",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typedoc": "^0.25.7",
    "typescript": "^5.3.3"
  }
}
